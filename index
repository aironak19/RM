<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ronak Mehta — People Strategy, Engineered</title>
<meta name="description" content="Ronak Mehta · Senior HR Business Partner. 12 years scaling global SaaS organizations with data, design and AI. Mumbai, India.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --ink:#0B0F1E;
  --ink-2:#0E1428;
  --surface:#121A33;
  --surface-2:#16203E;
  --line:rgba(150,170,230,.14);
  --text:#E9EDFB;
  --muted:#92A0C4;
  --coral:#FF6B5E;
  --violet:#8B7CFF;
  --teal:#5ED3C8;
  --grad:linear-gradient(96deg,#FF6B5E 0%,#C76BD0 48%,#8B7CFF 100%);
  --display:'Sora',sans-serif;
  --body:'Manrope',sans-serif;
  --mono:'IBM Plex Mono',monospace;
  --r:18px;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  background:var(--ink);
  color:var(--text);
  font-family:var(--body);
  font-size:16.5px;
  line-height:1.65;
  overflow-x:hidden;
  -webkit-font-smoothing:antialiased;
}
::selection{background:rgba(139,124,255,.35)}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}

/* ---------- progress bar ---------- */
#progress{position:fixed;top:0;left:0;height:3px;width:0%;background:var(--grad);z-index:1000;border-radius:0 3px 3px 0}

/* ---------- ambient background ---------- */
.bg-grid{
  position:fixed;inset:0;z-index:-2;pointer-events:none;
  background-image:linear-gradient(rgba(146,160,196,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(146,160,196,.05) 1px,transparent 1px);
  background-size:56px 56px;
  mask-image:radial-gradient(ellipse 90% 70% at 50% 0%,#000 30%,transparent 75%);
  -webkit-mask-image:radial-gradient(ellipse 90% 70% at 50% 0%,#000 30%,transparent 75%);
}
.bg-glow{position:fixed;z-index:-3;border-radius:50%;filter:blur(120px);opacity:.5;pointer-events:none}
.bg-glow.a{width:560px;height:560px;background:rgba(139,124,255,.20);top:-180px;right:-120px;animation:drift 16s ease-in-out infinite alternate}
.bg-glow.b{width:480px;height:480px;background:rgba(255,107,94,.12);top:40vh;left:-200px;animation:drift 20s ease-in-out infinite alternate-reverse}
@keyframes drift{from{transform:translate(0,0) scale(1)}to{transform:translate(60px,40px) scale(1.12)}}

/* ---------- nav ---------- */
nav{
  position:fixed;top:14px;left:50%;transform:translateX(-50%);
  width:min(1080px,calc(100% - 32px));
  display:flex;align-items:center;justify-content:space-between;
  padding:10px 14px 10px 20px;
  background:rgba(13,18,38,.62);
  border:1px solid var(--line);
  border-radius:99px;
  backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);
  z-index:900;
  animation:navIn .8s cubic-bezier(.2,.8,.2,1) both;
}
@keyframes navIn{from{opacity:0;transform:translate(-50%,-24px)}to{opacity:1;transform:translate(-50%,0)}}
.brand{font-family:var(--display);font-weight:700;font-size:17px;letter-spacing:-.01em;display:flex;align-items:center;gap:10px}
.brand .dot{width:9px;height:9px;border-radius:50%;background:var(--grad);box-shadow:0 0 14px rgba(255,107,94,.8);animation:pulse 2.4s ease-in-out infinite}
@keyframes pulse{0%,100%{transform:scale(1);opacity:1}50%{transform:scale(1.35);opacity:.7}}
.nav-links{display:flex;gap:4px;align-items:center}
.nav-links a{font-size:14px;font-weight:600;color:var(--muted);padding:8px 14px;border-radius:99px;transition:color .25s,background .25s}
.nav-links a:hover{color:var(--text);background:rgba(146,160,196,.1)}
.nav-cta{
  font-size:14px;font-weight:700;color:#0B0F1E!important;
  background:var(--text);padding:9px 18px!important;border-radius:99px;
  transition:transform .25s,box-shadow .25s!important;
}
.nav-cta:hover{background:var(--text)!important;color:#0B0F1E!important;transform:translateY(-1px);box-shadow:0 6px 24px rgba(233,237,251,.25)}
@media(max-width:760px){.nav-links a:not(.nav-cta){display:none}}

/* ---------- shared ---------- */
.wrap{width:min(1120px,calc(100% - 48px));margin:0 auto}
section{position:relative;padding:110px 0}
.eyebrow{
  font-family:var(--mono);font-size:12.5px;font-weight:500;letter-spacing:.16em;text-transform:uppercase;
  color:var(--muted);display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;
}
.eyebrow::before{content:'';width:26px;height:1px;background:var(--grad)}
h2{font-family:var(--display);font-weight:700;font-size:clamp(30px,4.4vw,46px);letter-spacing:-.025em;line-height:1.12;margin-bottom:16px}
.lede{color:var(--muted);font-size:18px;max-width:620px}
.grad-text{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}

/* reveal on scroll */
.rv{opacity:0;transform:translateY(34px);transition:opacity .9s cubic-bezier(.2,.8,.2,1),transform .9s cubic-bezier(.2,.8,.2,1)}
.rv.in{opacity:1;transform:none}
.rv.d1{transition-delay:.08s}.rv.d2{transition-delay:.16s}.rv.d3{transition-delay:.24s}.rv.d4{transition-delay:.32s}

/* ---------- hero ---------- */
.hero{min-height:100svh;display:flex;align-items:center;padding:140px 0 80px;overflow:hidden}
.hero-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:56px;align-items:center}
.hero h1{
  font-family:var(--display);font-weight:800;
  font-size:clamp(42px,6.4vw,76px);
  line-height:1.04;letter-spacing:-.035em;margin:14px 0 22px;
}
.hero h1 .line{display:block;overflow:hidden;padding-bottom:.09em;margin-bottom:-.09em}
.hero h1 .line span{display:inline-block;transform:translateY(110%);animation:riseUp 1s cubic-bezier(.2,.8,.2,1) forwards}
.hero h1 .line:nth-child(2) span{animation-delay:.12s}
.hero h1 .line:nth-child(3) span{animation-delay:.24s}
@keyframes riseUp{to{transform:translateY(0)}}
.hero .sub{color:var(--muted);font-size:18.5px;max-width:540px;margin-bottom:34px;animation:fadeUp 1s .45s cubic-bezier(.2,.8,.2,1) both}
.hero .sub b{color:var(--text);font-weight:600}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
.hero-eyebrow{animation:fadeUp .9s .05s cubic-bezier(.2,.8,.2,1) both}
.cta-row{display:flex;gap:14px;flex-wrap:wrap;animation:fadeUp 1s .6s cubic-bezier(.2,.8,.2,1) both}
.btn{
  display:inline-flex;align-items:center;gap:9px;
  font-weight:700;font-size:15px;padding:14px 26px;border-radius:99px;
  transition:transform .25s,box-shadow .25s,background .25s;cursor:pointer;border:none;
}
.btn-primary{background:var(--grad);color:#fff;box-shadow:0 8px 30px rgba(199,107,208,.35)}
.btn-primary:hover{transform:translateY(-3px);box-shadow:0 14px 40px rgba(199,107,208,.5)}
.btn-ghost{background:transparent;color:var(--text);border:1px solid var(--line)}
.btn-ghost:hover{background:rgba(146,160,196,.08);transform:translateY(-3px)}
.btn svg{width:17px;height:17px}

/* headshot */
.portrait{position:relative;justify-self:center;animation:fadeUp 1.1s .3s cubic-bezier(.2,.8,.2,1) both}
.portrait .ring{
  position:absolute;inset:-14px;border-radius:36px;
  background:conic-gradient(from var(--ang,0deg),#FF6B5E,#C76BD0,#8B7CFF,#5ED3C8,#FF6B5E);
  filter:blur(.5px);opacity:.9;
  animation:spin 9s linear infinite;
}
@property --ang{syntax:'<angle>';initial-value:0deg;inherits:false}
@keyframes spin{to{--ang:360deg}}
.portrait .ring::after{content:'';position:absolute;inset:3px;border-radius:33px;background:var(--ink)}
.portrait .frame{
  position:relative;width:min(360px,76vw);aspect-ratio:1008/1064;border-radius:28px;overflow:hidden;
  border:1px solid var(--line);
  box-shadow:0 30px 80px rgba(0,0,0,.55);
}
.portrait .frame img{width:100%;height:100%;object-fit:cover;transform:scale(1.02);transition:transform .8s ease}
.portrait:hover .frame img{transform:scale(1.06)}
.chip{
  position:absolute;display:flex;flex-direction:column;gap:1px;
  background:rgba(15,21,44,.82);border:1px solid var(--line);border-radius:14px;
  padding:10px 16px;backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);
  box-shadow:0 14px 38px rgba(0,0,0,.45);
  animation:floaty 5.5s ease-in-out infinite;
}
.chip .v{font-family:var(--mono);font-weight:600;font-size:18px}
.chip .k{font-size:11px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase}
.chip.c1{top:8%;left:-58px;animation-delay:.2s}
.chip.c1 .v{color:var(--teal)}
.chip.c2{bottom:18%;right:-54px;animation-delay:1.4s}
.chip.c2 .v{color:var(--coral)}
.chip.c3{bottom:-26px;left:14%;animation-delay:2.6s}
.chip.c3 .v{color:var(--violet)}
@keyframes floaty{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@media(max-width:980px){
  .hero-grid{grid-template-columns:1fr;gap:70px}
  .portrait{order:-1}
  .chip.c1{left:-10px}.chip.c2{right:-10px}
}

/* hero chart (signature) */
.hero-chart{
  position:absolute;left:0;right:0;bottom:0;height:240px;z-index:-1;pointer-events:none;opacity:.85;
  mask-image:linear-gradient(to right,transparent,#000 12%,#000 88%,transparent);
  -webkit-mask-image:linear-gradient(to right,transparent,#000 12%,#000 88%,transparent);
}
.hero-chart svg{width:100%;height:100%}
.attr-line{stroke:url(#lineGrad);stroke-width:2.5;fill:none;stroke-linecap:round;
  stroke-dasharray:1600;stroke-dashoffset:1600;animation:draw 3s 1s cubic-bezier(.4,0,.2,1) forwards}
.attr-fill{fill:url(#fillGrad);opacity:0;animation:fadeIn 1.4s 3.2s forwards}
.thresh{stroke:var(--coral);stroke-width:1.4;stroke-dasharray:7 8;opacity:0;animation:fadeIn 1s 2s forwards}
.thresh-label,.end-label{font-family:var(--mono);font-size:11.5px;opacity:0;animation:fadeIn 1s 2.4s forwards}
.end-dot{fill:var(--teal);opacity:0;animation:fadeIn .6s 3.6s forwards}
.end-dot-pulse{fill:none;stroke:var(--teal);opacity:0;animation:ping 2.4s 4s ease-out infinite}
@keyframes draw{to{stroke-dashoffset:0}}
@keyframes fadeIn{to{opacity:1}}
@keyframes ping{0%{opacity:.8;r:5}100%{opacity:0;r:22}}

.scroll-hint{
  position:absolute;bottom:26px;left:50%;transform:translateX(-50%);
  font-family:var(--mono);font-size:11px;letter-spacing:.22em;text-transform:uppercase;color:var(--muted);
  display:flex;flex-direction:column;align-items:center;gap:10px;
  animation:fadeIn 1s 2.8s both;
}
.scroll-hint .bar{width:1px;height:42px;background:linear-gradient(var(--muted),transparent);position:relative;overflow:hidden}
.scroll-hint .bar::after{content:'';position:absolute;top:-40%;left:0;width:100%;height:40%;background:var(--text);animation:scrollDrop 1.8s ease-in-out infinite}
@keyframes scrollDrop{to{top:110%}}
</style>
<style>
/* ---------- marquee ---------- */
.marquee{
  border-top:1px solid var(--line);border-bottom:1px solid var(--line);
  padding:20px 0;overflow:hidden;background:rgba(15,21,44,.4);
  display:flex;white-space:nowrap;
}
.marquee .track{display:flex;gap:0;animation:scrollX 36s linear infinite;flex-shrink:0}
.marquee span{
  font-family:var(--mono);font-size:13.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);
  padding:0 26px;display:inline-flex;align-items:center;gap:26px;
}
.marquee span::after{content:'◆';font-size:8px;color:var(--violet)}
@keyframes scrollX{to{transform:translateX(-100%)}}

/* ---------- metrics ---------- */
.metrics-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:54px}
.metric{
  position:relative;background:linear-gradient(180deg,rgba(22,32,62,.7),rgba(15,21,44,.55));
  border:1px solid var(--line);border-radius:var(--r);padding:30px 28px;overflow:hidden;
  transition:transform .35s cubic-bezier(.2,.8,.2,1),border-color .35s;
}
.metric:hover{transform:translateY(-6px);border-color:rgba(139,124,255,.4)}
.metric::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--grad);opacity:0;transition:opacity .35s}
.metric:hover::before{opacity:1}
.metric .num{font-family:var(--mono);font-weight:600;font-size:clamp(34px,3.6vw,46px);letter-spacing:-.03em;line-height:1.1}
.metric .num small{font-size:.55em;color:var(--muted);font-weight:500}
.metric .lbl{font-size:14px;color:var(--muted);margin-top:8px}
.metric .tag{position:absolute;top:18px;right:18px;font-family:var(--mono);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);opacity:.7}
.metric.hero-metric .num{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
@media(max-width:860px){.metrics-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:540px){.metrics-grid{grid-template-columns:1fr}}

/* eNPS gauge */
.gauge-wrap{display:flex;align-items:center;gap:18px}
.gauge{position:relative;width:92px;height:92px;flex-shrink:0}
.gauge svg{transform:rotate(-90deg)}
.gauge .bgc{stroke:rgba(146,160,196,.15);fill:none;stroke-width:7}
.gauge .fgc{stroke:url(#gaugeGrad);fill:none;stroke-width:7;stroke-linecap:round;
  stroke-dasharray:226;stroke-dashoffset:226;transition:stroke-dashoffset 2.2s cubic-bezier(.4,0,.2,1)}
.gauge .gv{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-weight:600;font-size:24px}

/* ---------- capability cards ---------- */
.cap-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:54px}
.cap{
  position:relative;background:linear-gradient(180deg,rgba(22,32,62,.6),rgba(15,21,44,.5));
  border:1px solid var(--line);border-radius:var(--r);padding:34px 32px;overflow:hidden;
  transition:transform .4s cubic-bezier(.2,.8,.2,1),border-color .4s,box-shadow .4s;
}
.cap:hover{transform:translateY(-7px);border-color:rgba(255,107,94,.35);box-shadow:0 24px 60px rgba(0,0,0,.4)}
.cap .glow{position:absolute;width:340px;height:340px;border-radius:50%;background:radial-gradient(circle,rgba(139,124,255,.16),transparent 65%);top:var(--my,50%);left:var(--mx,50%);transform:translate(-50%,-50%);opacity:0;transition:opacity .4s;pointer-events:none}
.cap:hover .glow{opacity:1}
.cap .icon{
  width:48px;height:48px;border-radius:13px;display:flex;align-items:center;justify-content:center;
  background:rgba(139,124,255,.12);border:1px solid rgba(139,124,255,.25);margin-bottom:20px;
}
.cap .icon svg{width:23px;height:23px;stroke:url(#iconGrad)}
.cap h3{font-family:var(--display);font-size:20px;font-weight:700;letter-spacing:-.015em;margin-bottom:10px}
.cap p{color:var(--muted);font-size:15px}
.cap .tags{display:flex;flex-wrap:wrap;gap:8px;margin-top:18px}
.cap .tags i{font-style:normal;font-family:var(--mono);font-size:11.5px;color:var(--muted);border:1px solid var(--line);padding:5px 11px;border-radius:99px}
@media(max-width:760px){.cap-grid{grid-template-columns:1fr}}

/* ---------- experience timeline ---------- */
.timeline{margin-top:64px;position:relative}
.timeline::before{
  content:'';position:absolute;left:7px;top:6px;bottom:6px;width:2px;
  background:linear-gradient(180deg,var(--coral),var(--violet) 55%,transparent);opacity:.5;
}
.job{position:relative;padding:0 0 64px 52px}
.job:last-child{padding-bottom:0}
.job::before{
  content:'';position:absolute;left:0;top:7px;width:16px;height:16px;border-radius:50%;
  background:var(--ink);border:2.5px solid var(--violet);box-shadow:0 0 0 5px rgba(139,124,255,.14);
}
.job.current::before{border-color:var(--coral);box-shadow:0 0 0 5px rgba(255,107,94,.16);animation:pulse 2.6s ease-in-out infinite}
.job .period{font-family:var(--mono);font-size:12.5px;letter-spacing:.1em;color:var(--muted);text-transform:uppercase}
.job h3{font-family:var(--display);font-size:clamp(21px,2.6vw,26px);font-weight:700;letter-spacing:-.02em;margin:8px 0 2px}
.job .co{font-size:15.5px;color:var(--muted);margin-bottom:18px}
.job .co b{color:var(--text);font-weight:600}
.job ul{list-style:none;display:grid;gap:11px}
.job li{position:relative;padding-left:24px;color:var(--muted);font-size:15.5px}
.job li::before{content:'';position:absolute;left:2px;top:9px;width:7px;height:7px;border-radius:2px;background:var(--grad);transform:rotate(45deg)}
.job li b{color:var(--text);font-weight:600}
.job .badge{
  display:inline-flex;align-items:center;gap:7px;margin-top:18px;
  font-family:var(--mono);font-size:12px;color:#FFD27D;
  border:1px solid rgba(255,210,125,.3);background:rgba(255,210,125,.08);
  padding:7px 14px;border-radius:99px;
}

/* ---------- artifacts ---------- */
.art-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:18px;margin-top:54px}
.art{
  position:relative;display:block;background:linear-gradient(180deg,rgba(22,32,62,.6),rgba(15,21,44,.5));
  border:1px solid var(--line);border-radius:var(--r);padding:32px;overflow:hidden;
  transition:transform .4s cubic-bezier(.2,.8,.2,1),border-color .4s,box-shadow .4s;
}
.art:hover{transform:translateY(-7px) scale(1.01);border-color:rgba(94,211,200,.4);box-shadow:0 26px 64px rgba(0,0,0,.45)}
.art .cat{font-family:var(--mono);font-size:11.5px;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);margin-bottom:14px;display:block}
.art h3{font-family:var(--display);font-size:21px;font-weight:700;letter-spacing:-.015em;margin-bottom:10px;display:flex;align-items:center;gap:10px}
.art p{color:var(--muted);font-size:15px}
.art .go{
  position:absolute;top:24px;right:24px;width:38px;height:38px;border-radius:50%;
  border:1px solid var(--line);display:flex;align-items:center;justify-content:center;
  transition:background .35s,transform .45s cubic-bezier(.2,.8,.2,1),border-color .35s;
}
.art .go svg{width:15px;height:15px;stroke:var(--text)}
.art:hover .go{background:var(--grad);border-color:transparent;transform:rotate(45deg)}
.art .shine{position:absolute;top:0;left:-80%;width:55%;height:100%;background:linear-gradient(105deg,transparent,rgba(233,237,251,.06),transparent);transform:skewX(-18deg);transition:left .8s ease}
.art:hover .shine{left:130%}
@media(max-width:760px){.art-grid{grid-template-columns:1fr}}

/* ---------- education / awards ---------- */
.split{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:54px}
.panel{background:linear-gradient(180deg,rgba(22,32,62,.6),rgba(15,21,44,.5));border:1px solid var(--line);border-radius:var(--r);padding:34px 32px}
.panel h3{font-family:var(--display);font-size:19px;font-weight:700;margin-bottom:24px;display:flex;align-items:center;gap:11px}
.panel h3 .ico{width:34px;height:34px;border-radius:10px;background:rgba(255,107,94,.12);border:1px solid rgba(255,107,94,.25);display:flex;align-items:center;justify-content:center}
.panel h3 .ico svg{width:17px;height:17px;stroke:var(--coral)}
.edu-item{display:flex;gap:16px;padding:15px 0;border-bottom:1px solid var(--line)}
.edu-item:last-child{border-bottom:none;padding-bottom:0}
.edu-item .yr{font-family:var(--mono);font-size:12.5px;color:var(--muted);min-width:46px;padding-top:3px}
.edu-item .t{font-weight:700;font-size:15.5px}
.edu-item .s{font-size:13.5px;color:var(--muted)}
@media(max-width:760px){.split{grid-template-columns:1fr}}

/* ---------- contact ---------- */
.contact{padding:130px 0 60px;text-align:center}
.contact h2{font-size:clamp(36px,6vw,64px);margin-bottom:20px}
.contact .lede{margin:0 auto 40px}
.contact-row{display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
.foot{
  margin-top:90px;padding:26px 0;border-top:1px solid var(--line);
  display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap;
  color:var(--muted);font-size:13.5px;
}
.foot .mono{font-family:var(--mono);font-size:12px}

@media(prefers-reduced-motion:reduce){
  *,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition-duration:.01ms!important}
  html{scroll-behavior:auto}
  .rv{opacity:1;transform:none}
  .hero h1 .line span{transform:none}
  .attr-line{stroke-dashoffset:0}
  .gauge .fgc{stroke-dashoffset:59!important}
}
</style>
</head>
<body>
<div id="progress"></div>
<div class="bg-grid"></div>
<div class="bg-glow a"></div>
<div class="bg-glow b"></div>

<svg width="0" height="0" style="position:absolute">
