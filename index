<script>
(function(){
  /* scroll progress */
  const bar=document.getElementById('progress');
  addEventListener('scroll',()=>{
    const h=document.documentElement;
    bar.style.width=(h.scrollTop/(h.scrollHeight-h.clientHeight)*100)+'%';
  },{passive:true});

  /* duplicate marquee track for seamless loop */
  const mq=document.getElementById('mq1');
  if(mq){const clone=mq.cloneNode(true);clone.removeAttribute('id');mq.parentNode.appendChild(clone);}

  /* reveal + counters + gauge */
  const ease=t=>1-Math.pow(1-t,4);
  function runCount(el){
    const target=parseFloat(el.dataset.target), dec=parseInt(el.dataset.decimal||0),
          pre=el.dataset.prefix||'', suf=el.dataset.suffix||'', dur=1800, t0=performance.now();
    function tick(now){
      const p=Math.min((now-t0)/dur,1), v=(target*ease(p)).toFixed(dec);
      el.innerHTML=pre+v+suf;
      if(p<1)requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }
  const reduced=matchMedia('(prefers-reduced-motion: reduce)').matches;
  const io=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting)return;
      e.target.classList.add('in');
      e.target.querySelectorAll('.count').forEach(c=>{
        if(c.dataset.done)return;c.dataset.done=1;
        if(reduced){c.innerHTML=(c.dataset.prefix||'')+c.dataset.target+(c.dataset.suffix||'');}
        else runCount(c);
      });
      const arc=e.target.querySelector('#enpsArc');
      if(arc&&!arc.dataset.done){arc.dataset.done=1;
        /* circumference 2πr = 226.2 ; eNPS 74 on a -100..100 scale shown as 74/100 fill (87% of arc) */
        requestAnimationFrame(()=>arc.style.strokeDashoffset=226-(226*0.87));
      }
      io.unobserve(e.target);
    });
  },{threshold:.18});
  document.querySelectorAll('.rv,.metric,.gauge').forEach(el=>io.observe(el));

  /* card mouse glow */
  document.querySelectorAll('.cap').forEach(card=>{
    card.addEventListener('pointermove',ev=>{
      const r=card.getBoundingClientRect();
      card.style.setProperty('--mx',(ev.clientX-r.left)+'px');
      card.style.setProperty('--my',(ev.clientY-r.top)+'px');
    });
  });
})();
</script>
